#!/usr/bin/with-contenv bash

# Wait for container services to fully start
sleep 30

echo "[beet-auto-import] Service started"

while true; do
    # Only process directories that haven't been modified in the last 30 minutes
    # (ensures downloads are complete before importing)
    echo "[beet-auto-import] $(date) - Scanning for completed downloads..."

    for dir in /downloads/soulseek /downloads/usenet; do
        if [ -d "$dir" ]; then
            # Find subdirectories not modified in 30+ minutes
            find "$dir" -mindepth 1 -maxdepth 1 -type d -mmin +30 2>/dev/null | while read -r album_dir; do
                # Skip if empty
                if [ -z "$(find "$album_dir" -name '*.flac' -o -name '*.mp3' -o -name '*.ogg' -o -name '*.m4a' 2>/dev/null | head -1)" ]; then
                    continue
                fi
                echo "[beet-auto-import] Importing: $album_dir"
                s6-setuidgid abc beet import -q "$album_dir" 2>&1
            done
        fi
    done

    echo "[beet-auto-import] $(date) - Scan complete. Sleeping 30 minutes..."
    sleep 1800
done
