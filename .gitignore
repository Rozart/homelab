# Environment files with secrets
**/.env
!**/.env.example

# Appdata directories (runtime data)
**/appdata/

# Keep Recyclarr config tracked
!stacks/recyclarr/appdata/
!stacks/recyclarr/appdata/recyclarr/
!stacks/recyclarr/appdata/recyclarr/configs/
stacks/recyclarr/appdata/*
!stacks/recyclarr/appdata/recyclarr/
stacks/recyclarr/appdata/recyclarr/*
!stacks/recyclarr/appdata/recyclarr/configs/
stacks/recyclarr/appdata/recyclarr/configs/*
!stacks/recyclarr/appdata/recyclarr/configs/recyclarr.yml

# Keep Caddyfile tracked
!stacks/caddy/appdata/
!stacks/caddy/appdata/Caddyfile
stacks/caddy/appdata/*
!stacks/caddy/appdata/Caddyfile

# Keep Soularr config tracked
!stacks/downloader/appdata/
!stacks/downloader/appdata/soularr/
!stacks/downloader/appdata/soularr/config.ini
stacks/downloader/appdata/*
!stacks/downloader/appdata/soularr/
stacks/downloader/appdata/soularr/*
!stacks/downloader/appdata/soularr/config.ini
